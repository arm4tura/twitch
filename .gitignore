# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ── Node / Electron ───────────────────────────────────────
node_modules/
dist/
build/
.vite/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Media (large binaries) ────────────────────────────────
*.mp4
*.mkv
*.mov
*.avi
*.webm
*.wav
*.mp3
*.flac
*.m4a

# ── Models / weights ──────────────────────────────────────
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.ggml

# ── Job artifacts (keep folders, ignore contents) ─────────
input/*
!input/.gitkeep
output/*
!output/.gitkeep
work/*
!work/.gitkeep
models/*
!models/.gitkeep

# ── OS / editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
